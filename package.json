{
  "name": "agora",
  "version": "0.1.0",
  "description": "A sandbox where AI agents negotiate, trade, and evolve their own coordination protocols",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "commitment-demo": "tsx src/scenarios/commitment-demo.ts",
    "compare": "tsx src/evolution/compare.ts",
    "dev": "tsx watch src/cli.ts",
    "events-demo": "tsx src/scenarios/events-demo.ts",
    "llm-auction": "tsx src/scenarios/llm-auction.ts",
    "arbitration-demo": "tsx src/scenarios/arbitration-demo.ts",
    "multi-party": "tsx src/scenarios/multi-party.ts",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
